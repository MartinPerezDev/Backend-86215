<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

      <!-- Card Principal estilo Messenger -->
      <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">

        <!-- Header del Chat -->
        <div class="card-header text-white d-flex justify-content-between align-items-center py-2 px-3"
          style="background-color: #1255a7; border-bottom: 1px solid rgba(0,0,0,0.1);">

          <div class="d-flex align-items-center gap-2">
            <img src="https://www.iconpacks.net/icons/2/free-facebook-messenger-icon-2881-thumb.png" alt="Logo"
              style="width: 35px; height: 35px; object-fit: contain; filter: brightness(1.1);">
            <h5 class="mb-0 fw-bold" style="letter-spacing: -0.5px;">Messenger</h5>
          </div>

          <!-- Contador con fondo semi-transparente para no chocar con el azul -->
          <div class="d-flex align-items-center px-3 py-1"
            style="background-color: rgba(255, 255, 255, 0.406); border-radius: 20px;">
            <span class="badge rounded-pill bg-success p-1 me-2 shadow-sm"> </span>
            <small id="countUsers" class="fw-bold">0</small>
          </div>
        </div>

        <!-- Cuerpo del Chat (Scrollable) -->
        <div id="chatBox" class="card-body p-4" style="height: 70vh; overflow-y: auto; background-color: #f0f2f5;">
          <!-- Los mensajes se insertarán aquí -->
        </div>

        <!-- Footer con Input -->
        <div class="card-footer bg-white border-0 py-3">
          <!-- Agregamos align-items-center para que todo esté alineado al medio -->
          <form id="formChat" class="d-flex gap-2 align-items-center">

            <input type="text" id="inputChat" class="form-control rounded-pill border-0 bg-light px-3"
              style="height: 45px; box-shadow: none;" placeholder="Escribe un mensaje..." required autocomplete="off">

            <!-- flex-shrink-0 evita que el botón se aplaste o deforme -->
            <button type="submit"
              class="btn d-flex align-items-center justify-content-center p-0 flex-shrink-0 shadow-sm"
              style="width: 45px; height: 45px; background-color: #0084FF; border: none; border-radius: 50%;">

              <img src="https://icons.veryicon.com/png/o/miscellaneous/admin-dashboard-flat-multicolor/send-message.png" alt="Enviar"
                style="width: 20px; height: 20px; filter: brightness(0) invert(1); object-fit: contain;">

            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/index.js"></script>